# 로컬에서 st.secrets 방식으로 테스트하고 싶을 때 사용하는 템플릿.
# 이 파일을 복사해 같은 폴더에 secrets.toml로 저장하세요(.gitignore에 이미 등록되어 있어
# 실수로 커밋되지 않습니다). .env 파일을 쓰는 경우 이 파일은 몰라도 됩니다 — 둘 다 있으면
# st.secrets(이 파일)가 우선 적용됩니다.
#
# Streamlit Community Cloud 배포 시에는 이 파일을 올리는 게 아니라, 앱 대시보드의
# Settings → Secrets 화면에 아래와 동일한 내용을 직접 입력합니다.

ANTHROPIC_API_KEY = "sk-ant-..."
